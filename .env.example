APP_NAME=ShopSmart
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# --- Sail (local Docker dev only — irrelevant when running via php artisan serve) ---
APP_PORT=8000
VITE_PORT=5173
FORWARD_DB_PORT=5432
WWWUSER=1000
WWWGROUP=1000

APP_LOCALE=th
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_TIMEZONE=Asia/Bangkok

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Supabase PostgreSQL ---------------------------------------------------
# Supabase Dashboard > Project Settings > Database > Connection string
# Transaction pooler (6543), not session mode (5432): session mode caps the
# *entire project* at pool_size total simultaneous connections (often just
# 15), and this app's persistent PDO connections (config/database.php) each
# hold one open indefinitely per Apache worker — a handful of workers across
# local dev + any deployed instance exhausts that fast. Transaction mode
# multiplexes many client connections onto the small backend pool instead.
DB_CONNECTION=pgsql
DB_HOST=YOUR_SUPABASE_HOST.pooler.supabase.com
DB_PORT=6543
DB_DATABASE=postgres
DB_USERNAME=postgres.YOUR_PROJECT_REF
DB_PASSWORD=YOUR_SUPABASE_DB_PASSWORD
DB_SSLMODE=require

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
# public = local disk (fine for local dev). In production on a host with an
# ephemeral filesystem (e.g. Render's free tier), switch to s3 — see the
# Supabase Storage block below — or uploads vanish on every restart/redeploy.
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=file
CACHE_PREFIX=shopsmart

# --- Supabase Storage (S3-compatible; only needed when FILESYSTEM_DISK=s3) ---
# Supabase Dashboard > Project Settings > Storage > S3 Connection, and create
# a public bucket under Storage first (its name goes in AWS_BUCKET).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=
AWS_ENDPOINT=https://YOUR_PROJECT_REF.supabase.co/storage/v1/s3
AWS_URL=https://YOUR_PROJECT_REF.supabase.co/storage/v1/object/public/YOUR_BUCKET
AWS_USE_PATH_STYLE_ENDPOINT=true

# --- Redis (เตรียมไว้สำหรับอนาคต: สลับ CACHE_STORE=redis / QUEUE_CONNECTION=redis) ---
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Mail (local: เขียนลง log / production: ใส่ SMTP จริง เช่น Resend, Mailgun) ---
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@shopsmart.test"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
